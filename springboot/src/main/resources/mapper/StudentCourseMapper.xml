<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.StudentCourseMapper">

    <select id="selectAll" resultType="com.example.entity.StudentCourse">
        select * from `student_course`
        <where>
            <if test="id != null"> and id = #{id}</if>
        </where>
        order by id desc
    </select>

    <select id="selectById" resultType="com.example.entity.StudentCourse">
        select * from `student_course` where id = #{id}
    </select>

    <delete id="deleteById">
        delete from `student_course` where id = #{id}
    </delete>

    <insert id="insert" parameterType="com.example.entity.StudentCourse" useGeneratedKeys="true" keyProperty="id">
        insert into `student_course`(student_id, course_id, select_time, status)
        values (#{studentId}, #{courseId}, #{selectTime}, #{status})
    </insert>

    <update id="updateById" parameterType="com.example.entity.StudentCourse">
        update `student_course`
        <set>
            <if test="studentId != null">student_id = #{studentId},</if>
            <if test="courseId != null">course_id = #{courseId},</if>
            <if test="selectTime != null">select_time = #{selectTime},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        where id = #{id}
    </update>

</mapper>